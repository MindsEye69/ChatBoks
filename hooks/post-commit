#!/bin/sh
# ChatBoks managed post-commit hook template.
#
# Prefer installing a project-specific hook with:
#   python install.py <project> --install-hook
#
# The installer writes absolute PYTHON, CHATBOKS_ROOT, CONFIG, and PROJECT
# values so this works from any Git-managed project on Windows or Unix.

echo "Install this hook with: python install.py <project> --install-hook" >&2
exit 0
